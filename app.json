{
  "expo": {
    "name": "Strings",
    "slug": "strings",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "strings",
    "newArchEnabled": true,
    "icon": "./assets/images/icon.png",
    "android": {
      "backgroundColor": "#000000",
      "package": "com.garado.strings",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "./plugins/withAndroidConfigChanges",
      "./plugins/withAndroidTheme"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {}
    }
  }
}
